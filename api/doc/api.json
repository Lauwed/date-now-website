			],
			"uri": "/user",
			"schema": {
				"id": "integer",
				"username": "string?",
				"email": "string",
				"role": "USER | AUTHOR",
				"totpSeed": "string?",
				"link": "string?",
				"picture": "foreignKey-media",
				"subscribedAt": "timestamp?",
				"isSupporter": "boolean",
				"createdAt": "timestamp"
			},
			"body": {
				"post": {
					"schema": {
						"username": "string?",
						"email": "string",
						"role": "USER | AUTHOR",
						"link": "string?"
