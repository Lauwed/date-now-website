{
	"tables": [
		{
			"name": {
				"singular": "authentication",
				"plural": "authentication"
			},
			"description": "Author authentication via magic link and TOTP.",
			"uri": "/auth",
			"includedEndpoints": [],
			"customEndpoints": [
				{
					"name": "subscribe",
					"description": "Sends a confirmation email to the given address.",
					"uri": "/subscribe",
					"method": "POST",
					"tokenRequired": false,
					"responses": [
						{
							"code": 200,
							"response": "Confirmation mail sent"
						},
						{
							"code": 400,
							"response": "Invalid email address"
						},
						{
							"code": 409,
							"response": "Email already subscribed"
						}
					],
					"body": {
						"email": "string"
					}
				},
				{
					"name": "confirm subscribe",
					"description": "Confirms the subscription via the token received by email.",
					"uri": "/subscribe/confirm",
					"method": "GET",
					"tokenRequired": false,
					"responses": [
						{
							"code": 200,
							"response": "User successfully subscribed"
						},
						{
							"code": 400,
							"response": "Invalid or expired token"
						},
						{
							"code": 404,
							"response": "User not found"
						}
					],
					"queryParameters": [
						{
							"label": "Token",
							"name": "token",
							"type": "string",
							"required": true
						}
					]
				},
				{
					"name": "generate author totp seed",
					"description": "Generates a TOTP seed for an existing author account.",
					"uri": "/seed",
					"method": "POST",
					"responses": [
						{
							"code": 200,
							"response": {
								"message": "Author successfully registered",
								"totpseed": "string"
							}
						},
						{
							"code": 400,
							"response": "Invalid email address"
						},
						{
							"code": 404,
							"response": "Author not found"
						}
					],
					"body": {
						"email": "string"
					}
				},
				{
					"name": "author registration",
					"description": "Creates a new author account and returns the TOTP seed.",
					"uri": "/register",
					"method": "POST",
					"responses": [
						{
							"code": 200,
							"response": {
								"message": "Author successfully registered",
								"totpseed": "string"
							}
						},
						{
							"code": 400,
							"response": "Invalid or missing fields"
						},
						{
							"code": 409,
							"response": "Email already registered"
						}
					],
					"body": {
						"username": "string",
						"email": "string"
					}
				},
				{
					"name": "author login",
					"description": "Sends a magic link to the author's email address.",
					"uri": "/login",
					"method": "POST",
					"tokenRequired": false,
					"responses": [
						{
							"code": 200,
							"response": "Email sent"
						},
						{
							"code": 400,
							"response": "Invalid email address"
						},
						{
							"code": 404,
							"response": "Author not found"
						}
					],
					"body": {
						"email": "string"
					}
				},
				{
					"name": "TOTP login",
					"description": "Validates the TOTP code and returns a JWT.",
					"uri": "/login/totp",
					"method": "POST",
					"tokenRequired": false,
					"responses": [
						{
							"code": 200,
							"response": {
								"message": "Successfully logged in",
								"token": "string"
							}
						},
						{
							"code": 400,
							"response": "Invalid or expired TOTP code"
						},
						{
							"code": 404,
							"response": "User not found"
						}
					],
					"body": {
						"email": "string",
						"code": "string"
					}
				}
			]
		},
		{
			"name": {
				"singular": "media",
				"plural": "medias"
			},
			"description": "Images and other media files. Served at /uploads/media/{uuid}/image.webp.",
			"uriParameters": [
				{
					"name": "id",
					"type": "integer",
					"defaultValue": 1,
					"isPrimary": true
				}
			],
			"uri": "/media",
			"schema": {
				"id": "integer",
				"alt": "string",
				"url": "string",
				"width": "double?",
				"height": "double?"
			},
			"includedEndpoints": [
				"GET-list",
				"GET-single",
				"POST",
				"DELETE"
			],
			"body": {
				"post": {
					"multipart": true,
					"fields": [
						{
							"name": "textAlternatif",
							"label": "Text alternatif",
							"type": "string",
							"required": true
						},
						{
							"name": "file",
							"label": "Image (JPEG, PNG, GIF, WebP, BMP, TIFF — max 5 MB)",
							"type": "file",
							"required": true
						}
					]
				}
			}
		},
		{
			"name": {
				"singular": "user",
				"plural": "users"
			},
			"description": "Subscribers and authors of the newsletter.",
			"uriParameters": [
				{
					"name": "id",
					"type": "integer",
					"defaultValue": 1,
					"isPrimary": true
				}
			],
			"uri": "/user",
			"schema": {
				"id": "integer",
				"username": "string?",
				"email": "string",
				"role": "USER | AUTHOR",
				"totpSeed": "string?",
				"link": "string?",
				"picture": "foreignKey-media",
				"subscribedAt": "timestamp?",
				"isSupporter": "boolean",
				"createdAt": "timestamp"
			},
			"body": {
				"post": {
					"schema": {
						"username": "string?",
						"email": "string",
						"role": "USER | AUTHOR",
						"link": "string?",
						"pictureId": "integer?"
					},
					"defaultValue": "{\n\t\"username\": \"DevGirl_\",\n\t\"email\": \"contact@lauradurieux.dev\",\n\t\"role\": \"AUTHOR\",\n\t\"link\": \"hihihuhuh.com\"\n}"
				},
				"put": {
					"schema": {
						"username": "string?",
						"email": "string",
						"role": "USER | AUTHOR",
						"link": "string?",
						"subscribedAt": "timestamp?",
						"isSupporter": "boolean",
						"pictureId": "integer?"
					}
				}
			}
		},
		{
			"name": {
				"singular": "tag",
				"plural": "tags"
			},
			"description": "Tags used to categorize issues.",
			"uriParameters": [
				{
					"name": "name",
					"type": "string",
					"defaultValue": "Computer Science",
					"isPrimary": true
				}
			],
			"uri": "/tag",
			"schema": {
				"name": "string",
				"color": "string"
			},
			"includedEndpoints": [
				"GET-list",
				"GET-single",
				"POST",
				"PUT",
				"DELETE"
			],
			"body": {
				"post": {
					"schema": {
						"name": "string",
						"color": "string"
					},
					"defaultValue": "{\n\t\"name\": \"Computer Science\",\n\t\"color\": \"#6b3a9e\"\n}"
				},
				"put": {
					"schema": {
						"color": "string"
					},
					"defaultValue": "{\n\t\"color\": \"#123456\"\n}"
				}
			}
		},
		{
			"name": {
				"singular": "sponsor",
				"plural": "sponsors"
			},
			"description": "Sponsors associated with newsletter issues.",
			"uriParameters": [
				{
					"name": "name",
					"type": "string",
					"defaultValue": "Firefox",
					"isPrimary": true
				}
			],
			"uri": "/sponsor",
			"schema": {
				"name": "string",
				"link": "string"
			},
			"includedEndpoints": [
				"GET-list",
				"GET-single",
				"POST",
				"PUT",
				"DELETE"
			],
			"body": {
				"post": {
					"schema": {
						"name": "string",
						"link": "string"
					},
					"defaultValue": "{\n\t\"name\": \"Firefox\",\n\t\"link\": \"firefox.com\"\n}"
				},
				"put": {
					"schema": {
						"link": "string"
					},
					"defaultValue": "{\n\t\"link\": \"firefox.com\"\n}"
				}
			}
		},
		{
			"name": {
				"singular": "issue",
				"plural": "issues"
			},
			"description": "Newsletter issues — drafts, published, and archived.",
			"uriParameters": [
				{
					"name": "id",
					"type": "integer",
					"defaultValue": 1,
					"isPrimary": true
				}
			],
			"uri": "/issue",
			"schema": {
				"id": "integer",
				"slug": "string",
				"title": "string",
				"subtitle": "string",
				"cover": "foreignKey-media",
				"createdAt": "datetime",
				"publishedAt": "datetime?",
				"updatedAt": "datetime?",
				"issueNumber": "integer",
				"excerpt": "string",
				"content": "string",
				"isSponsored": "boolean",
				"status": "DRAFT | PUBLISHED | ARCHIVED",
				"openedMailCount": "integer"
			},
			"response": {
				"get-single": {
					"id": "integer",
					"slug": "string",
					"title": "string",
					"subtitle": "string",
					"cover": "foreignKey-media",
					"createdAt": "datetime",
					"publishedAt": "datetime?",
					"updatedAt": "datetime?",
					"issueNumber": "integer",
					"excerpt": "string",
					"content": "string",
					"isSponsored": "boolean",
					"status": "DRAFT | PUBLISHED | ARCHIVED",
					"openedMailCount": "integer",
					"views": "integer",
					"authors": "array-user",
					"tags": "array-tag",
					"sponsors": "array-sponsor"
				}
			},
			"listParameters": [
				{
					"name": "page",
					"label": "Page",
					"type": "integer",
					"defaultValue": 1,
					"min": 1
				},
				{
					"name": "limit",
					"label": "Limit",
					"type": "integer",
					"defaultValue": 20,
					"min": 1,
					"max": 100
				},
				{
					"name": "status",
					"label": "Status",
					"type": "select",
					"options": [
						{ "name": "DRAFT", "label": "Draft" },
						{ "name": "PUBLISHED", "label": "Published" },
						{ "name": "ARCHIVED", "label": "Archived" }
					]
				}
			],
			"body": {
				"post": {
					"schema": {
						"slug": "string?",
						"title": "string",
						"subtitle": "string",
						"issueNumber": "integer",
						"excerpt": "string",
						"content": "string",
						"isSponsored": "boolean?",
						"status": "DRAFT | PUBLISHED | ARCHIVED",
						"coverId": "integer?"
					},
					"defaultValue": "{\n\t\"title\": \"Les code potes m'ont payés pour faire cette API en C\",\n\t\"subtitle\": \"c'est très rigolo\",\n\t\"issueNumber\": 80,\n\t\"excerpt\": \"La lecture va vous étonner\",\n\t\"content\": \"Ahbahdakor\",\n\t\"status\": \"DRAFT\"\n}"
				},
				"put": {
					"schema": {
						"slug": "string?",
						"title": "string",
						"subtitle": "string",
						"issueNumber": "integer",
						"excerpt": "string",
						"content": "string",
						"isSponsored": "boolean?",
						"status": "DRAFT | PUBLISHED | ARCHIVED",
						"coverId": "integer?"
					},
					"defaultValue": "{\n\t\"title\": \"Les code potes m'ont payés pour faire cette API en C\",\n\t\"subtitle\": \"c'est très rigolo\",\n\t\"issueNumber\": 80,\n\t\"excerpt\": \"La lecture va vous étonner\",\n\t\"content\": \"Ahbahdakor\",\n\t\"status\": \"DRAFT\"\n}"
				}
			}
		},
		{
			"name": {
				"singular": "issue tag",
				"plural": "issue tags"
			},
			"description": "Tags associated with an issue. URI: /issue/{id}/tag.",
			"uriParameters": [
				{
					"name": "tagName",
					"type": "string",
					"defaultValue": "Software",
					"isPrimary": true
				},
				{
					"name": "id",
					"type": "integer",
					"defaultValue": 1
				}
			],
			"uri": "/issue/{ID}/tag",
			"schema": {
				"tagId": "integer",
				"issueId": "integer"
			},
			"includedEndpoints": [
				"GET-list",
				"POST",
				"DELETE"
			]
		},
		{
			"name": {
				"singular": "issue author",
				"plural": "issue authors"
			},
			"description": "Authors associated with an issue. URI: /issue/{id}/author.",
			"uriParameters": [
				{
					"name": "userId",
					"type": "integer",
					"defaultValue": 1,
					"isPrimary": true
				},
				{
					"name": "id",
					"type": "integer",
					"defaultValue": 1
				}
			],
			"uri": "/issue/{ID}/author",
			"schema": {
				"authorId": "integer",
				"issueId": "integer"
			},
			"includedEndpoints": [
				"GET-list",
				"POST",
				"DELETE"
			]
		},
		{
			"name": {
				"singular": "issue sponsor",
				"plural": "issue sponsors"
			},
			"description": "Sponsors associated with an issue. URI: /issue/{id}/sponsor.",
			"uriParameters": [
				{
					"name": "sponsorName",
					"type": "string",
					"defaultValue": "Lilymonad",
					"isPrimary": true
				},
				{
					"name": "id",
					"type": "integer",
					"defaultValue": 1
				}
			],
			"uri": "/issue/{ID}/sponsor",
			"schema": {
				"sponsorId": "integer",
				"issueId": "integer"
			},
			"includedEndpoints": [
				"GET-list",
				"POST",
				"DELETE"
			]
		},
		{
			"name": {
				"singular": "view",
				"plural": "views"
			},
			"description": "Page view tracking per issue, identified by hashed IP.",
			"uriParameters": [
				{
					"name": "id",
					"type": "integer",
					"defaultValue": 1,
					"isPrimary": true
				}
			],
			"uri": "/view",
			"schema": {
				"id": "integer",
				"timestamp": "integer",
				"hashedIp": "string",
				"issueId": "integer"
			},
			"includedEndpoints": [
				"GET-list",
				"POST"
			],
			"tokenRequired": {
				"post": false
			}
		}
	]
}
