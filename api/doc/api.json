{
	"tables": [
		{
			"name": {
				"singular": "authentication",
				"plural": "authentication"
			},
			"uri": "/auth",
			"uriParameters": [],
			"customEndpoints": [
				{
					"name": "subscribe",
					"uri": "/subscribe",
					"method": "POST",
					"tokenRequired": false,
					"responses": [
						{
							"code": 200,
							"response": "Confirmation mail sent"
						}
					],
					"body": {
						"email": "string"
					}
				},
				{
					"name": "confirm subscribe",
					"uri": "/subscribe/confirm",
					"method": "GET",
					"tokenRequired": false,
					"responses": [
						{
							"code": 200,
							"response": "User successfully subscribed"
						}
					],
					"queryParameters": [
						{
							"label": "Token",
							"name": "token",
							"type": "string",
							"required": true
						}
					]
				},
				{
					"name": "generate author totp seed",
					"uri": "/seed",
					"method": "POST",
					"responses": [
						{
							"code": 200,
							"response": {
								"message": "Author successfully registered",
								"totpseed": "string"
							}
						}
					],
					"body": {
						"email": "string"
					}
				},
				{
					"name": "author registration",
					"uri": "/register",
					"method": "POST",
					"responses": [
						{
							"code": 200,
							"response": {
								"message": "Author successfully registered",
								"totpseed": "string"
							}
						}
					],
					"body": {
						"username": "string",
						"email": "string"
					}
				},
				{
					"name": "author login",
					"uri": "/login",
					"method": "POST",
					"tokenRequired": false,
					"responses": [
						{
							"code": 200,
							"response": "Email sent"
						}
					],
					"body": {
						"email": "string"
					}
				},
				{
					"name": "TOTP login",
					"uri": "/login/totp",
					"method": "POST",
					"tokenRequired": false,
					"responses": [
						{
							"code": 200,
							"response": {
								"message": "Successfully logged in",
								"token": "string"
							}
						}
					],
					"body": {
						"email": "string",
						"code": "string"
					}
				}
			],
			"body": {},
			"schema": {},
			"includedEndpoints": []
		},
		{
			"name": {
				"singular": "media",
				"plural": "medias"
			},
			"uriParameters": [
				{
					"name": "id",
					"type": "integer",
					"defaultValue": "1",
					"isPrimary": true
				}
			],
			"uri": "/media",
			"schema": {
				"id": "integer",
				"alt": "string",
				"url": "string",
				"width": "double?",
				"height": "double?"
			},
			"includedEndpoints": ["GET-list", "GET-single", "POST", "DELETE"],
			"body": {
				"post": {
					"multipart": true,
					"fields": [
						{
							"name": "textAlternatif",
							"label": "Text alternatif",
							"type": "string",
							"required": true
						},
						{
							"name": "file",
							"label": "Image (JPEG, PNG, GIF, WebP, BMP, TIFF — max 5 MB)",
							"type": "file",
							"required": true
						}
					]
				}
			}
		},
		{
